# =============================================================================
# GMAT Prep — environment variables
# Copy this file to `.env.local` (it is git-ignored) and fill in your values.
#
#   cp .env.example .env.local
#
# The values below are the DEFAULT local Supabase demo keys. If you run the
# local stack with `npx supabase start`, these work as-is — no editing needed.
# For a hosted Supabase project, replace all three with the values from
# Project Settings -> API.
# =============================================================================

# Public Supabase URL + anon (publishable) key — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# Service-role key — SERVER ONLY. Used by `npm run seed`. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# -----------------------------------------------------------------------------
# Analytics (PostHog) — OPTIONAL. Leave unset and analytics is fully disabled.
# Create a free project at posthog.com and paste the Project API key below.
# EU region: also set NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
#            and    NEXT_PUBLIC_POSTHOG_ASSETS=https://eu-assets.i.posthog.com
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
