    "id": "g5-quant-05",
    "section": "quant",
    "type": "problem_solving",
    "topic": "remainders",
    "difficulty": "medium",
    "orderIndex": 0,
    "stem": "What is the remainder when $7^{4}$ is divided by 5?",
    "assets": {},
    "choices": [
      {
        "key": "A",
        "text": "1"
      },
      {
        "key": "B",
        "text": "0"
